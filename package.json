{
  "name": "luminaweave-pro",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "npx cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "npx cross-env NODE_ENV=production vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "postbuild": "node -e \"const fs = require('fs'); fs.copyFileSync('dist/public/index.html', 'dist/public/404.html');\"",
    "build:netlify": "npx cross-env NODE_ENV=production vite build && esbuild netlify/functions/server.ts --bundle --platform=node --target=node18 --outfile=netlify/functions/server.js",
    "start": "npx cross-env NODE_ENV=production node dist/index.js",
    "deploy": "pnpm build && npx gh-pages -d dist/public",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
